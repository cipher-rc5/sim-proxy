{
  "name": "sim-proxy",
  "version": "0.0.2",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "bun run scripts/build.ts",
    "type-check": "bunx tsc --noEmit",
    "deploy": "bun run type-check && bun run test && bunx wrangler deploy",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "generate-key": "bun run scripts/generate-key.ts",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "typescript": "5.9.3",
    "wrangler": "4.74.0"
  },
  "dependencies": {
    "@hono/zod-validator": "0.7.6",
    "@scalar/hono-api-reference": "0.10.3",
    "@scalar/openapi-types": "0.6.0",
    "@t3-oss/env-core": "0.13.10",
    "hono": "4.12.8",
    "zod": "4.3.6"
  }
}
